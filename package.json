{
  "name": "youtube-interface",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["server", "web"],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:web",
    "dev:server": "npm --workspace server run dev",
    "dev:web": "npm --workspace web run dev",
    "build": "npm --workspace web run build && npm --workspace server run build",
    "start": "npm --workspace server run start"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
